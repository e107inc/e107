#!/usr/bin/env bash
# e107 test harness CLI
#
# Spins up isolated Docker test environments per worktree+matrix combo,
# bind-mounts the worktree into a PHP+Apache container, and drives
# Codeception against it.
#
# Quickstart:
#   e107_tests/bin/e107-tests up                # PHP 8.3 + MariaDB 10.11
#   e107_tests/bin/e107-tests urls              # show URL + DB conn info
#   e107_tests/bin/e107-tests run unit          # run unit suite
#   e107_tests/bin/e107-tests run acceptance    # run acceptance suite
#   e107_tests/bin/e107-tests shell             # interactive bash in web
#   e107_tests/bin/e107-tests down              # tear down this env
#
# See `e107-tests help` for the full command list.

set -euo pipefail

# ---------------------------------------------------------------------------
# Paths and constants
# ---------------------------------------------------------------------------

SCRIPT_PATH=$(readlink -f -- "$0")
SCRIPT_DIR=$(dirname -- "$SCRIPT_PATH")
TESTS_DIR=$(dirname -- "$SCRIPT_DIR")
APP_PATH=$(dirname -- "$TESTS_DIR")
DOCKER_DIR="$TESTS_DIR/docker"
COMPOSE_FILE="$DOCKER_DIR/compose.yml"
ENVS_DIR="$DOCKER_DIR/.envs"
ACTIVE_LINK="$ENVS_DIR/_active"
MANAGED_CONFIG="$TESTS_DIR/config.docker.yml"

DEFAULT_PHP=8.3
DEFAULT_DB=mariadb:10.11
DEFAULT_DB_NAME=e107
DEFAULT_DB_USER=e107
DEFAULT_DB_PASSWORD=e107
DEFAULT_DB_ROOT_PASSWORD=root

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

err() { printf 'error: %s\n' "$*" >&2; exit 1; }
note() { printf '%s\n' "$*" >&2; }

have() { command -v "$1" >/dev/null 2>&1; }

require_docker() {
    have docker || err "docker is required but not on PATH"
    docker compose version >/dev/null 2>&1 \
        || err "the 'docker compose' plugin is required (got: $(docker compose version 2>&1 || true))"
}

# Returns ":O" when the engine is Podman (supports ephemeral overlay
# mounts that keep the host worktree pristine across acceptance tests),
# empty string otherwise. With overlay the container can install vendor/,
# write e107_config.php, and create hash dirs without leaking back to the
# host. With plain bind, those writes will dirty the worktree — agents on
# Docker should be prepared to clean up after acceptance runs.

# Slug an arbitrary string into something safe for compose project names.
slug() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/-\+/-/g; s/^-//; s/-$//'
}

# Short, stable hash of a string. We only need uniqueness across worktrees,
# not cryptographic strength, so 8 hex chars is plenty.
hash8() {
    printf '%s' "$1" | sha1sum | cut -c1-8
}

# Derive a compose project name from worktree path + PHP + DB.
project_name() {
    local php=$1 db=$2
    printf 'e107-%s-php%s-%s' \
        "$(hash8 "$APP_PATH")" \
        "$(slug "$php")" \
        "$(slug "$db")"
}

state_dir() {
    printf '%s/%s' "$ENVS_DIR" "$1"
}

# Resolve the env to operate on. Order of precedence:
#   1. --env <project> on the command line
#   2. ENV variables E107_PHP_VERSION / E107_DB_IMAGE
#   3. The _active symlink saved by the most recent `up`
#   4. Defaults
resolve_env() {
    local explicit=${EXPLICIT_PROJECT:-}
    if [ -n "$explicit" ]; then
        PROJECT=$explicit
        if [ ! -f "$(state_dir "$PROJECT")/stack.env" ]; then
            err "no such env: $PROJECT (try: e107-tests list)"
        fi
        # shellcheck disable=SC1090
        . "$(state_dir "$PROJECT")/stack.env"
        return
    fi

    local php=${E107_PHP_VERSION:-} db=${E107_DB_IMAGE:-}
    if [ -z "$php" ] || [ -z "$db" ]; then
        if [ -L "$ACTIVE_LINK" ]; then
            local active
            active=$(basename -- "$(readlink -- "$ACTIVE_LINK")")
            if [ -f "$(state_dir "$active")/stack.env" ]; then
                # shellcheck disable=SC1090
                . "$(state_dir "$active")/stack.env"
                PROJECT=$active
                return
            fi
        fi
    fi
    E107_PHP_VERSION=${php:-$DEFAULT_PHP}
    E107_DB_IMAGE=${db:-$DEFAULT_DB}
    PROJECT=$(project_name "$E107_PHP_VERSION" "$E107_DB_IMAGE")
}

# Write the per-env state file. Everything compose.yml needs to know
# lives here; sourcing it is enough to bring the env back.
write_stack_env() {
    local dir
    dir=$(state_dir "$PROJECT")
    mkdir -p "$dir"
    cat > "$dir/stack.env" <<EOF
# Generated by e107-tests. Do not hand-edit; re-run \`e107-tests up\` instead.
COMPOSE_PROJECT_NAME=$PROJECT
E107_PHP_VERSION=$E107_PHP_VERSION
E107_DB_IMAGE=$E107_DB_IMAGE
E107_APP_PATH=$APP_PATH
E107_DB_NAME=$DEFAULT_DB_NAME
E107_DB_USER=$DEFAULT_DB_USER
E107_DB_PASSWORD=$DEFAULT_DB_PASSWORD
E107_DB_ROOT_PASSWORD=$DEFAULT_DB_ROOT_PASSWORD
E107_WITH_XDEBUG=$WITH_XDEBUG
E107_WITH_XDEBUG_TAG=$([ "$WITH_XDEBUG" = yes ] && echo '-xdebug' || true)
EOF
    # shellcheck disable=SC1090
    . "$dir/stack.env"
}

compose() {
    require_docker
    local dir
    dir=$(state_dir "$PROJECT")
    if [ -f "$dir/stack.env" ]; then
        env $(grep -v '^#' "$dir/stack.env" | xargs -d '\n') \
            docker compose --project-directory "$DOCKER_DIR" -f "$COMPOSE_FILE" "$@"
    else
        docker compose --project-directory "$DOCKER_DIR" -f "$COMPOSE_FILE" "$@"
    fi
}

mark_active() {
    mkdir -p "$ENVS_DIR"
    ln -sfn "$PROJECT" "$ACTIVE_LINK"
}

# Write a config.docker.yml that points Codeception at the running stack.
# This file overrides config.yml (a user's VM setup) but is itself
# overridable by config.local.yml (personal tweaks), so the cascade is:
#   sample → yml → docker → local
write_managed_config() {
    cat > "$MANAGED_CONFIG" <<EOF
# Managed by e107-tests. Generated for project: $PROJECT
# Edit \`config.local.yml\` for personal overrides; that file wins.
---
app_path: '../'
deployer: 'local'
# Acceptance/functional run PhpBrowser *inside* the web container, so the app is
# reachable at localhost there. (Humans browse via the host-published port from
# 'e107-tests urls'.)
url: 'http://localhost/'
# The WebDriver browser runs in the separate 'selenium' container, where
# localhost is the browser itself, not the web server. It reaches the app by the
# compose service alias instead. The fixture trusts host 'web' (trusted_hosts in
# the sample dump) so e107's host-header check accepts it.
webdriver_url: 'http://web/'
db:
  host: 'db'
  port: '3306'
  dbname: '$DEFAULT_DB_NAME'
  user: 'root'
  password: '$DEFAULT_DB_ROOT_PASSWORD'
  populate: true
  dump_path: 'tests/_data/e107_v2.3.0.sample.sql'
# WebDriver suite drives the dedicated 'selenium' service over the compose
# network. '/wd/hub' is the legacy route standalone-chrome serves.
selenium:
  host: 'selenium'
  port: '4444'
  path: '/wd/hub'
EOF
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_up() {
    PHP=$DEFAULT_PHP
    DB=$DEFAULT_DB
    WITH_XDEBUG=no
    while [ $# -gt 0 ]; do
        case $1 in
            --php) PHP=$2; shift 2 ;;
            --db) DB=$2; shift 2 ;;
            --xdebug) WITH_XDEBUG=yes; shift ;;
            -h|--help) cmd_help; exit 0 ;;
            *) err "unknown flag: $1" ;;
        esac
    done

    E107_PHP_VERSION=$PHP
    E107_DB_IMAGE=$DB
    PROJECT=$(project_name "$PHP" "$DB")
    write_stack_env
    mark_active
    write_managed_config

    note ">> Bringing up env: $PROJECT (PHP $PHP / $DB)"
    compose up -d --build --wait
    cmd_install
    cmd_urls
}

cmd_down() {
    local remove_volumes=
    while [ $# -gt 0 ]; do
        case $1 in
            --volumes|-v) remove_volumes=--volumes; shift ;;
            *) err "unknown flag: $1" ;;
        esac
    done
    resolve_env
    note ">> Tearing down: $PROJECT"
    compose down --remove-orphans $remove_volumes || true

    # Clean up the managed config only if it belongs to this project.
    if [ -f "$MANAGED_CONFIG" ] && grep -q "Generated for project: $PROJECT" "$MANAGED_CONFIG"; then
        rm -f "$MANAGED_CONFIG"
    fi
    rm -rf -- "$(state_dir "$PROJECT")"
    if [ -L "$ACTIVE_LINK" ] && [ "$(readlink -- "$ACTIVE_LINK")" = "$PROJECT" ]; then
        rm -f "$ACTIVE_LINK"
    fi
}

cmd_install() {
    resolve_env
    note ">> Installing test dependencies (composer, submodules)"
    # Matches existing CI behavior: `composer update` so the install
    # works across PHP 8.1–8.4. composer.lock will show as modified on
    # the host; that's expected — `e107-tests clean` restores it.
    compose exec -T -w /var/www/html/e107_tests web composer update --prefer-dist --no-progress
    if [ -e "$APP_PATH/.git" ]; then
        ( cd "$APP_PATH" && git submodule update --init --recursive --remote >/dev/null 2>&1 ) || true
    fi
}

cmd_urls() {
    resolve_env
    local port
    port=$(compose port web 80 2>/dev/null | awk -F: '{print $NF}' | tail -n1)
    if [ -z "$port" ]; then
        err "env $PROJECT does not appear to be running (try: e107-tests up)"
    fi
    cat <<EOF
Project:      $PROJECT
PHP version:  $E107_PHP_VERSION
DB image:     $E107_DB_IMAGE
App URL:      http://localhost:$port/
Admin URL:    http://localhost:$port/e107_admin/
DB (host):    127.0.0.1:$(compose port db 3306 2>/dev/null | awk -F: '{print $NF}' | tail -n1)
              user=$E107_DB_USER  pw=$E107_DB_PASSWORD  db=$E107_DB_NAME
              root pw=$E107_DB_ROOT_PASSWORD
DB (in-net):  db:3306 (use this from inside containers)
EOF
}

cmd_status() {
    resolve_env
    compose ps
}

cmd_logs() {
    resolve_env
    compose logs --tail=200 -f "$@"
}

cmd_exec() {
    resolve_env
    if [ $# -eq 0 ]; then
        err "usage: e107-tests exec <command>..."
    fi
    compose exec -w /var/www/html web "$@"
}

cmd_shell() {
    resolve_env
    compose exec -w /var/www/html web bash
}

cmd_db_shell() {
    resolve_env
    compose exec db sh -c "mariadb -uroot -p\"\$MYSQL_ROOT_PASSWORD\" \"\$MYSQL_DATABASE\""
}

cmd_run() {
    resolve_env
    # Build: codecept run [<suite>] --steps [user args...]
    # --steps goes before user args so a trailing `--` separator (which
    # codecept uses to mark positionals) still works as intended.
    local cc_args=(run)
    local suite=${1:-}
    case $suite in
        ''|all) ;;
        unit|acceptance|functional)
            cc_args+=("$suite"); shift ;;
        *)
            cc_args+=("$suite"); shift ;;
    esac
    cc_args+=(--steps "$@")
    compose exec -w /var/www/html/e107_tests web ./vendor/bin/codecept "${cc_args[@]}"
}

cmd_reset() {
    resolve_env
    note ">> Resetting database for $PROJECT"
    compose exec -T db sh -c '
        mariadb -uroot -p"$MYSQL_ROOT_PASSWORD" -e "
            DROP DATABASE IF EXISTS \`$MYSQL_DATABASE\`;
            CREATE DATABASE \`$MYSQL_DATABASE\`;
            GRANT ALL PRIVILEGES ON \`$MYSQL_DATABASE\`.* TO \`$MYSQL_USER\`@\`%\`;
            FLUSH PRIVILEGES;"
    '
    note ">> Removing test-written app state (e107_config.php, hash dirs)"
    compose exec -T -w /var/www/html web sh -c '
        rm -f e107_config.php e107_config.php.bak
        rm -rf e107_system/000000test e107_media/000000test
    '
}

# Wipe acceptance-test artifacts that the e107 installer creates in the
# bind-mounted worktree. Only touches well-known untracked paths —
# never anything tracked by git.
#
# Files written by container-side www-data end up on the host with a
# subuid the host user can't directly chown/unlink. We handle that three
# ways, in order of robustness:
#   1. If the stack is up, rm inside the container (www-data owns the
#      files there — no perm trouble).
#   2. Otherwise, if `podman unshare` is available, rm via the user
#      namespace (works because the host user owns the subuid range).
#   3. Otherwise, attempt a host-side rm and report what couldn't be
#      removed.
cmd_clean() {
    note ">> Cleaning acceptance-test artifacts from $APP_PATH"

    local docroot_files='e107_config.php e107_config.php.bak e107Install.log NUL'
    local hash_dirs='e107_system/000000test e107_media/000000test
                     e107_system/416f4602e3 e107_media/416f4602e3'
    local theme_copies='e107_themes/basic-light e107_themes/testcore
                        e107_themes/testkubrick e107_plugins/thing'

    cd -- "$APP_PATH" || err "cannot cd to $APP_PATH"

    # Pick a remover. Prefer container-side rm if a web container is up
    # for the active env (most permissions-clean).
    local remover='host'
    if resolve_env 2>/dev/null \
       && compose ps --services --status running 2>/dev/null | grep -qx web; then
        remover='container'
    elif have podman; then
        remover='unshare'
    fi
    note "(using $remover-side rm for files with subuid ownership)"

    _rm() {
        case $remover in
            container)
                compose exec -T -w /var/www/html web rm -rf -- "$@" ;;
            unshare)
                podman unshare rm -rf -- "$@" ;;
            *)
                rm -rf -- "$@" ;;
        esac
    }

    local removed=0
    for f in $docroot_files; do
        if [ -e "$f" ]; then
            _rm "$f" && removed=$((removed + 1))
        fi
    done
    for d in $hash_dirs; do
        if [ -d "$d" ]; then
            _rm "$d" && removed=$((removed + 1))
        fi
    done
    for d in $theme_copies; do
        if [ -d "$d" ] && [ -z "$(git ls-files -- "$d" 2>/dev/null)" ]; then
            _rm "$d" && removed=$((removed + 1))
        fi
    done

    # Restore tracked files modified by install / composer update.
    # `git restore` is a no-op on files that aren't modified.
    if [ -e .git ]; then
        for f in e107.htaccess e107_tests/composer.lock; do
            if [ -f "$f" ] && ! git diff --quiet -- "$f" 2>/dev/null; then
                git restore -- "$f" && removed=$((removed + 1))
                note "restored $f"
            fi
        done
    fi

    note ">> Removed/restored $removed item(s)"
}

cmd_list() {
    if [ ! -d "$ENVS_DIR" ]; then
        echo "(no envs)"
        return
    fi
    printf '%-50s %-8s %-22s %s\n' PROJECT PHP DB WORKTREE
    local active_target=
    [ -L "$ACTIVE_LINK" ] && active_target=$(readlink -- "$ACTIVE_LINK")
    for dir in "$ENVS_DIR"/*/; do
        [ -d "$dir" ] || continue
        local name
        name=$(basename -- "$dir")
        # Skip metadata entries like the _active symlink.
        case $name in _*) continue ;; esac
        # shellcheck disable=SC1090
        ( . "$dir/stack.env" 2>/dev/null
          marker=' '
          [ "$name" = "$active_target" ] && marker='*'
          printf '%s %-48s %-8s %-22s %s\n' \
              "$marker" "$name" "$E107_PHP_VERSION" "$E107_DB_IMAGE" "$E107_APP_PATH"
        )
    done
}

cmd_help() {
    cat <<'EOF'
e107-tests — Docker-backed test environments for e107

USAGE:
  e107-tests <command> [args...]
  e107-tests --env <project> <command> [args...]   # operate on a specific env

LIFECYCLE:
  up [--php X] [--db Y] [--xdebug]   Build, start, install deps, mark active.
                                     Default: PHP 8.3 + MariaDB 10.11.
  down [--volumes]                   Stop and remove this env.
  reset                              Drop+recreate DB, clear written app state.
  clean                              Wipe untracked acceptance-test artifacts
                                     from the host worktree (e107_config.php,
                                     install log, hash dirs, copied themes).
  install                            Re-run composer update inside the web container.

INSPECT:
  urls                               Print URL + DB connection info.
  status                             docker compose ps for the active env.
  logs [service]                     Tail logs (web, db, or both).
  list                               List envs for this worktree (active marked with *).

INTERACT:
  shell                              Bash inside the web container.
  db-shell                           Mariadb client inside the db container.
  exec <cmd>...                      Run a one-shot command in the web container.

TEST:
  run [unit|acceptance|functional] [args...]
                                     Run Codeception inside the web container.
                                     Extra args are passed through to `codecept`.

  Examples:
    e107-tests run unit
    e107-tests run unit --filter ConstantsTest
    e107-tests run acceptance tests/acceptance/0000_InstallCest.php

VERSIONS:
  Pick any PHP and DB image you like. Validated combos:
    PHP:  8.1, 8.2, 8.3, 8.4
    DB:   mariadb:10.6, mariadb:10.11, mariadb:11.4, mysql:8.0, mysql:5.7

  Each PHP+DB combo gets its own isolated stack. You can run several
  at once in the same worktree (e.g. for cross-version verification).

ISOLATION:
  Each worktree's project name is derived from the worktree path, so
  parallel agents in different worktrees never collide. Ports on the
  host are chosen by Docker; `e107-tests urls` reveals them.
EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

EXPLICIT_PROJECT=
WITH_XDEBUG=no

# Pre-parse global flags that can appear before the subcommand.
while [ $# -gt 0 ]; do
    case ${1:-} in
        --env) EXPLICIT_PROJECT=$2; shift 2 ;;
        --help|-h|help|'') cmd_help; exit 0 ;;
        *) break ;;
    esac
done

CMD=${1:-help}
[ $# -gt 0 ] && shift

case $CMD in
    up)         cmd_up "$@" ;;
    down)       cmd_down "$@" ;;
    install)    cmd_install "$@" ;;
    urls)       cmd_urls "$@" ;;
    status|ps)  cmd_status "$@" ;;
    logs)       cmd_logs "$@" ;;
    exec)       cmd_exec "$@" ;;
    shell|bash) cmd_shell "$@" ;;
    db-shell|mysql|mariadb) cmd_db_shell "$@" ;;
    run|test)   cmd_run "$@" ;;
    reset)      cmd_reset "$@" ;;
    clean)      cmd_clean "$@" ;;
    list|ls)    cmd_list "$@" ;;
    help|--help|-h) cmd_help ;;
    *)          err "unknown command: $CMD (try: e107-tests help)" ;;
esac
