{
    "name": "e107inc/e107-rector-tools",
    "description": "Rector tooling: downgrade modern PHP source to PHP 5.6 for the e107 v2 release artifact.",
    "license": "GPL-3.0-or-later",
    "require-dev": {
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "E107\\Rector\\": "custom-rules/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true,
        "allow-plugins": {
            "rector/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
